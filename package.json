{
  "name": "@vaultdotenv/cli",
  "version": "0.3.0",
  "description": "Drop-in dotenv replacement. One master key locally, everything else encrypted remotely.",
  "main": "src/index.js",
  "bin": {
    "vaultdotenv": "src/cli.js",
    "vde": "src/cli.js"
  },
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/unit/*.test.js test/integration/cli.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "test:api": "node --test test/integration/api.test.js",
    "test:legacy": "node test/test.js"
  },
  "keywords": [
    "dotenv",
    "secrets",
    "vault",
    "env",
    "encryption",
    "config",
    "environment-variables",
    "secret-management",
    "aes-256",
    "zero-knowledge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultdotenv/vaultdotenv"
  },
  "homepage": "https://vaultdotenv.io",
  "bugs": {
    "url": "https://github.com/vaultdotenv/vaultdotenv/issues"
  },
  "author": "Matt Redman",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  }
}
